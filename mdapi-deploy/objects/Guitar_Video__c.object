<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Represents a guitar lesson video available in the Guitar Academy catalog.</description>
    <enableBulkApi>true</enableBulkApi>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Guitar Video</label>
    <nameField>
        <label>Title</label>
        <type>Text</type>
    </nameField>
    <pluralLabel>Guitar Videos</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
    <fields>
        <fullName>YouTube_ID__c</fullName>
        <externalId>true</externalId>
        <label>YouTube ID</label>
        <length>20</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Level__c</fullName>
        <label>Level</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Beginner</fullName><default>false</default><label>Beginner</label></value>
                <value><fullName>Intermediate</fullName><default>false</default><label>Intermediate</label></value>
                <value><fullName>Advanced</fullName><default>false</default><label>Advanced</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Category__c</fullName>
        <label>Category</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Technique</fullName><default>false</default><label>Technique</label></value>
                <value><fullName>Theory</fullName><default>false</default><label>Theory</label></value>
                <value><fullName>Song Lesson</fullName><default>false</default><label>Song Lesson</label></value>
                <value><fullName>Gear &amp; Tone</fullName><default>false</default><label>Gear &amp; Tone</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Price__c</fullName>
        <label>Price</label>
        <precision>4</precision>
        <required>false</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Duration_Minutes__c</fullName>
        <label>Duration (minutes)</label>
        <precision>4</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
    </fields>
    <fields>
        <fullName>Is_Free_Preview__c</fullName>
        <defaultValue>false</defaultValue>
        <label>Free Preview</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <label>Description</label>
        <length>2000</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>Thumbnail_URL__c</fullName>
        <externalId>false</externalId>
        <formula>&quot;https://img.youtube.com/vi/&quot; &amp; YouTube_ID__c &amp; &quot;/mqdefault.jpg&quot;</formula>
        <label>Thumbnail URL</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
</CustomObject>
