    <label>Video Purchase</label>
    <nameField>
        <displayFormat>VP-{0000}</displayFormat>
        <label>Purchase Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Video Purchases</pluralLabel>
    <searchLayouts/>
    <sharingModel>ControlledByParent</sharingModel>
    <visibility>Public</visibility>
